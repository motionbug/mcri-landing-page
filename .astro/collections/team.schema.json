{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "photo": {
      "type": "string"
    },
    "linkedin": {
      "type": "string",
      "format": "uri"
    },
    "order": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "title",
    "photo",
    "linkedin",
    "order"
  ]
}