{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "credentials": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "credlyBadges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "badgeId": {
            "type": "string"
          },
          "imageSrc": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "icon",
    "order",
    "credentials"
  ]
}