{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "student": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "imageSrc": {
      "type": "string"
    },
    "projectUrl": {
      "type": "string",
      "format": "uri"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "imageSrc"
  ]
}