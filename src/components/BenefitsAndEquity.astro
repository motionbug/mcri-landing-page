---
const benefits = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
    label: 'Food & board provided',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    label: 'Health insurance',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    label: 'Monthly stipend',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    label: 'Housing across the street',
  },
];
---

<section class="bg-warm-white py-20" aria-labelledby="benefits-heading">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

      <!-- Benefits column -->
      <div>
        <h2 id="benefits-heading" class="font-display font-bold text-3xl text-mcri-navy mb-3">
          We take care of our students.
        </h2>
        <p class="font-body text-slate mb-8">
          We created a place where we would want to send our own loved ones.
        </p>
        <ul class="flex flex-col gap-4">
          {benefits.map(b => (
            <li class="flex items-center gap-4 p-4 bg-white rounded-lg border border-mist">
              <span class="text-mcri-teal shrink-0" aria-hidden="true">
                <Fragment set:html={b.icon} />
              </span>
              <span class="font-body text-charcoal font-medium">{b.label}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Equity column -->
      <div class="bg-mcri-navy text-white p-8 rounded-xl border-l-4 border-mcri-teal">
        <h3 class="font-display font-bold text-2xl mb-4 leading-tight">
          At least 50% girls and young women.
        </h3>
        <p class="font-body text-white/85 leading-relaxed">
          In order to create change, it starts early by teaching boys and young men how to respect women. By being vigilant in including women in these spaces, we break down barriers and show that women belong in all places that men do.
        </p>
      </div>

    </div>
  </div>
</section>
