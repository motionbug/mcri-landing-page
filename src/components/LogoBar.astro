---
import EmptyState from './EmptyState.astro';

interface Logo {
  src: string;
  alt: string;
  href?: string;
  logoClass?: string;
}

interface Props {
  heading?: string;
  logos: Logo[];
}

const { heading, logos } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="bg-warm-white py-16" aria-labelledby={heading ? 'logobar-heading' : undefined}>
  <div class="max-w-screen-xl mx-auto px-6">
    {heading && (
      <h2
        id="logobar-heading"
        class="font-display font-bold text-xl text-mcri-navy text-center mb-10"
      >
        {heading}
      </h2>
    )}

    {logos.length === 0 ? (
      <EmptyState
        heading="Our partners."
        body="We're currently updating our employer partner list. Please check back soon."
      />
    ) : (
      <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16">
        {logos.map(logo => (
          logo.href ? (
            <a
              href={logo.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-20 w-full max-w-[14rem] items-center justify-center opacity-70 transition-opacity duration-200 hover:opacity-100"
              aria-label={`${logo.alt} (opens in new tab)`}
            >
              <img
                src={`${base}${logo.src.replace(/^\//, '')}`}
                alt={logo.alt}
                class={`max-h-12 w-full object-contain ${logo.logoClass ?? ''}`}
                width="180"
                height="48"
              />
            </a>
          ) : (
            <div class="flex h-20 w-full max-w-[14rem] items-center justify-center opacity-70">
              <img
                src={`${base}${logo.src.replace(/^\//, '')}`}
                alt={logo.alt}
                class={`max-h-12 w-full object-contain ${logo.logoClass ?? ''}`}
                width="180"
                height="48"
              />
            </div>
          )
        ))}
      </div>
    )}
  </div>
</section>
