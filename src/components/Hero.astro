---
interface Props {
  eyebrow?: string;
  headline: string;
  body: string;
  imageSrc: string;
  imageAlt?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  ceiLogoSrc?: string;
}

const {
  eyebrow,
  headline,
  body,
  imageSrc,
  imageAlt = '',
  primaryCta,
  secondaryCta,
  ceiLogoSrc,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const b = base.replace(/\/$/, '');
---

<section
  id="hero-section"
  data-base={base}
  class="relative min-h-screen flex items-center"
  aria-labelledby="hero-heading"
  style={`background-image: url('${base}${imageSrc.replace(/^\//, '')}'); background-size: cover; background-position: center;`}
>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-mcri-navy/72" aria-hidden="true"></div>

  <div class="relative z-10 max-w-screen-xl mx-auto px-6 py-24 pt-32 w-full">
    <div class="max-w-[560px]">
      {eyebrow && (
        <p class="font-body text-xs font-semibold uppercase tracking-[0.15em] text-v-ochre mb-4">
          {eyebrow}
        </p>
      )}

      <h1
        id="hero-heading"
        class="font-display font-bold text-4xl md:text-5xl text-white leading-tight mb-4"
      >
        {headline}
      </h1>

      {ceiLogoSrc && (
        <div class="flex items-center gap-3 mb-6">
          <span class="font-body text-sm text-white/70">Powered by</span>
          <img
            src={`${base}${ceiLogoSrc.replace(/^\//, '')}`}
            alt="Jamf Community Education Initiatives"
            class="h-8 w-auto"
            width="120"
            height="28"
          />
        </div>
      )}

      <p class="font-body text-lg text-white/85 leading-relaxed mb-10">
        {body}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={`${b}${primaryCta.href}`}
          class="px-7 py-3.5 bg-cei-orange text-white font-display font-semibold text-base rounded-md hover:bg-orange-600 transition-colors duration-200 text-center min-h-11 flex items-center justify-center"
        >
          {primaryCta.label}
        </a>
        {secondaryCta && (
          <a
            href={`${b}${secondaryCta.href}`}
            class="px-7 py-3.5 bg-transparent text-white font-display font-semibold text-base rounded-md border-2 border-white/70 hover:border-white hover:bg-white/10 transition-all duration-200 text-center min-h-11 flex items-center justify-center"
          >
            {secondaryCta.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const el = document.getElementById('hero-section');
  const base = el.dataset.base.replace(/\/$/, '');
  const images = ['hero-home.jpg', 'students.jpg', 'campus.jpg'];
  const pick = images[Math.floor(Math.random() * images.length)];
  el.style.backgroundImage = `url('${base}/images/${pick}')`;
</script>
