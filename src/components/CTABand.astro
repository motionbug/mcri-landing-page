---
interface Props {
  heading: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  headingId?: string;
}

const { heading, primaryCta, secondaryCta, headingId } = Astro.props;
const base = import.meta.env.BASE_URL;
const b = base.replace(/\/$/, '');
const sectionId = headingId ?? `cta-${heading.toLowerCase().replace(/\s+/g, '-').slice(0, 20)}`;
---

<section class="bg-mcri-navy py-20" aria-labelledby={sectionId}>
  <div class="max-w-screen-xl mx-auto px-6 text-center">
    <h2
      id={sectionId}
      class="font-display font-bold text-3xl md:text-4xl text-white mb-10"
    >
      {heading}
    </h2>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryCta.href.startsWith('http') ? primaryCta.href : `${b}${primaryCta.href}`}
        class="px-8 py-4 bg-cei-orange text-white font-display font-semibold text-base rounded-md hover:bg-orange-600 transition-colors duration-200 min-h-11 flex items-center justify-center"
      >
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href.startsWith('http') ? secondaryCta.href : `${b}${secondaryCta.href}`}
          class="px-8 py-4 bg-transparent text-white font-display font-semibold text-base rounded-md border-2 border-white/70 hover:border-white hover:bg-white/10 transition-all duration-200 min-h-11 flex items-center justify-center"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
