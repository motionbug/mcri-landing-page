---
interface Props {
  eyebrow?: string;
  heading: string;
  body: string;
  imageSrc?: string;
  imageAlt?: string;
  imagePosition?: 'left' | 'right';
  link?: { label: string; href: string };
  background?: 'white' | 'warm-white';
  headingId?: string;
}

const {
  eyebrow,
  heading,
  body,
  imageSrc,
  imageAlt = '',
  imagePosition = 'right',
  link,
  background = 'warm-white',
  headingId,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const b = base.replace(/\/$/, '');
const sectionId = headingId ?? `split-${heading.toLowerCase().replace(/\s+/g, '-').slice(0, 20)}`;
const bgClass = background === 'white' ? 'bg-white' : 'bg-warm-white';
---

<section class={`${bgClass} py-20`} aria-labelledby={sectionId}>
  <div class="max-w-screen-xl mx-auto px-6">
    <div class={`flex flex-col ${imagePosition === 'left' ? 'md:flex-row-reverse' : 'md:flex-row'} gap-12 md:gap-16 items-center`}>

      <!-- Text column -->
      <div class="flex-1 min-w-0">
        {eyebrow && (
          <p class="font-body text-xs font-semibold uppercase tracking-[0.15em] text-mcri-teal mb-3">
            {eyebrow}
          </p>
        )}
        <h2
          id={sectionId}
          class="font-display font-bold text-3xl md:text-4xl text-mcri-navy mb-6 leading-tight"
        >
          {heading}
        </h2>
        <p class="font-body text-base text-charcoal leading-relaxed mb-6">
          {body}
        </p>
        {link && (
          <a
            href={link.href.startsWith('http') ? link.href : `${b}${link.href}`}
            class="inline-flex items-center gap-2 font-display font-semibold text-mcri-teal hover:text-mcri-navy transition-colors duration-200 group"
          >
            {link.label}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:translate-x-1 transition-transform duration-200">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        )}
        <slot />
      </div>

      <!-- Image column -->
      {imageSrc && (
        <div class="flex-1 min-w-0 w-full">
          <img
            src={`${base}${imageSrc.replace(/^\//, '')}`}
            alt={imageAlt}
            class="w-full aspect-[4/3] object-cover rounded-xl shadow-lg"
            width="600"
            height="450"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </div>
</section>
