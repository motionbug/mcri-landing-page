---
import CurriculumBadge from './CurriculumBadge.astro';

interface Props {
  heading: string;
  body: string;
  badgeId?: string;
  imageSrc?: string;
  badgeName?: string;
  headingId?: string;
}

const {
  heading,
  body,
  badgeId,
  imageSrc,
  badgeName = 'MCRI Professional',
  headingId = 'badge-showcase-heading',
} = Astro.props;
---

<section class="bg-white py-20 text-center" aria-labelledby={headingId}>
  <div class="max-w-screen-xl mx-auto px-6">
    <h2 id={headingId} class="font-display font-bold text-3xl text-mcri-navy mb-4">
      {heading}
    </h2>
    <p class="font-body text-slate max-w-xl mx-auto mb-10 leading-relaxed">
      {body}
    </p>

    <div class="flex justify-center">
      <div class="scale-150">
        <CurriculumBadge
          badgeId={badgeId}
          imageSrc={imageSrc}
          badgeName={badgeName}
        />
      </div>
    </div>
  </div>
</section>
